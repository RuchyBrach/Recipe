<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RecipeMAUI.RecipeList"
             Title="RecipeList">
    <VerticalStackLayout>
    <Grid ColumnDefinitions="Auto" RowDefinitions="Auto, *" HorizontalOptions="Center" RowSpacing="10" ColumnSpacing="10">
        <Button x:Name="NewRecipeBtn" Text="New Recipe" Grid.Column="0" Grid.Row="0" BackgroundColor="Gray"/>
        <ListView x:Name="RecipeLst" Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <Grid RowDefinitions="Auto" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Image Grid.Column="0" Grid.Row="0" HeightRequest="75" Source="{Binding Path=[RecipePic]}"/>
                            <Label Grid.Column="1" Grid.Row="0" Text="{Binding Path=[RecipeName]}"/>
                        </Grid>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
    </VerticalStackLayout>
</ContentPage>